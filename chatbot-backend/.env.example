GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
KNOWLEDGE_BASE_PATH=./knowledge_base
VECTOR_STORE_PATH=./vector_store
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
SIMILARITY_THRESHOLD=0.4
EMBEDDING_MODEL=all-MiniLM-L6-v2
